# Copy to .env and adjust

# Portal UI
PORTAL_PORT=8080

# Tavle whiteboard (exposed for board iframes)
TAVLE_PORT=5050
TAVLE_PUBLIC_URL=http://localhost:5050

# Allow portal to embed Tavle boards
TAVLE_EMBED_FRAME_ANCESTORS=http://localhost:8080,http://127.0.0.1:8080

# Set after first-time setup in the portal UI, or paste token from http://localhost:5050/setup
ADMIN_API_TOKEN=

POSTGRES_PASSWORD=whiteboard
