# Copy to .env and adjust (Docker Compose loads .env from this directory).

FLASK_ENV=production
PORT=5050
POSTGRES_PASSWORD=change-me

# Comma-separated browser origins allowed for HTTP API + Socket.IO (not "*" in production).
# ALLOWED_ORIGINS=https://whiteboard.example.com

# Parent applications that iframe Tavle from another origin:
# TAVLE_EMBED_FRAME_ANCESTORS=http://127.0.0.1:8000,http://localhost:8000

# Optional extra stylesheets for /board pages (comma-separated paths or https? URLs).
# Same-origin paths start with /; external URLs need matching CSP style-src when using CSP_POLICY.
# TAVLE_EXTRA_STYLESHEETS=/static/css/brand.css

# Override full CSP only if you know what you are doing; external brand URLs then need
# matching style-src / font-src entries when using TAVLE_EXTRA_STYLESHEETS.
# CSP_POLICY=...
